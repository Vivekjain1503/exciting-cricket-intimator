# Cricket API Configuration
# Get your free API key from https://cricapi.com/
CRICKET_API_KEY=your_cricket_api_key_here

# Telegram Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Chat ID where notifications should be sent
# You can get this by sending a message to @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# Tracking Configuration
# Check interval in seconds (default: 60)
CHECK_INTERVAL=60

# Excitement threshold (0.0 to 1.0)
# Matches with excitement score above this will be reported
EXCITEMENT_THRESHOLD=0.5

# Enable debug logging
DEBUG=False

# Log file location
LOG_FILE=logs/cricket_tracker.log
